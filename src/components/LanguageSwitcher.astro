---
/**
 * Language switcher.
 *
 * UX architecture:
 *   • Renders ONLY the active language by default (flag + endonym), so the
 *     header stays uncluttered no matter how many languages are supported.
 *   • Clicking it reveals a search box. Typing a native name, English name, or
 *     ISO code filters the full catalogue down to a maximum of 5 suggestions.
 *   • Suggestions show the native endonym (e.g. 中文), never the English name.
 *   • Selecting a language writes a long-lived `lang` cookie (which the
 *     Cloudflare Worker honours over IP geo-detection) and navigates to the
 *     corresponding static route.
 *
 * Visuals use the official `flag-icons` package: `fi fi-<cc>` renders the SVG
 * flag via CSS, so no <img> requests are needed.
 */
import "flag-icons/css/flag-icons.min.css";
import {
  LANGUAGES,
  DEFAULT_LANG,
  LANG_BY_CODE,
  LANG_COOKIE,
} from "../i18n/config";

interface Props {
  /** Active language code for the page being rendered. */
  lang: string;
  /** Path within the current page, used to preserve location on switch. */
  pathname?: string;
  /** Localized UI strings for the switcher. */
  labels: { label: string; searchPlaceholder: string; noResults: string };
}

const { lang, pathname = "/", labels } = Astro.props;
const active = LANG_BY_CODE[lang] ?? LANG_BY_CODE[DEFAULT_LANG];

// Strip any existing language prefix so we can re-prefix on switch.
const knownPrefixes = LANGUAGES.map((l) => l.code).filter(
  (c) => c !== DEFAULT_LANG,
);
let basePath = pathname;
for (const code of knownPrefixes) {
  if (basePath === `/${code}` || basePath.startsWith(`/${code}/`)) {
    basePath = basePath.slice(code.length + 1) || "/";
    break;
  }
}

// Catalogue handed to the client for search. Endonym first — that is the label.
const catalogue = LANGUAGES.map((l) => ({
  code: l.code,
  endonym: l.endonym,
  english: l.englishName,
  flag: l.flag,
}));
---

<div
  class="ls-root relative"
  data-default-lang={DEFAULT_LANG}
  data-cookie={LANG_COOKIE}
  data-base-path={basePath}
  data-catalogue={JSON.stringify(catalogue)}
>
  <button
    type="button"
    class="ls-trigger inline-flex items-center gap-1.5 lg:gap-2 h-9 px-2.5 lg:px-3 rounded-pill border border-hairline bg-canvas-soft-2 text-sm font-medium text-ink cursor-pointer transition-colors hover:border-hairline-strong focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-link"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label={labels.label}
  >
    <span class={`fi fi-${active.flag} rounded-[2px] shrink-0`} aria-hidden="true"></span>
    {/* Full native name on desktop; compact ISO Alpha-2 country code on mobile/tablet. */}
    <span class="ls-active-name hidden lg:inline">{active.endonym}</span>
    <span class="ls-active-code lg:hidden uppercase">{active.flag}</span>
    <svg class="w-3.5 h-3.5 text-mute shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
    </svg>
  </button>

  <div
    class="ls-panel hidden absolute right-0 mt-2 w-64 z-50 rounded-lg border border-hairline bg-canvas shadow-lg overflow-hidden"
    role="dialog"
    aria-label={labels.label}
  >
    <div class="p-2 border-b border-hairline">
      <input
        type="text"
        class="ls-search w-full h-9 px-3 rounded-md border border-hairline bg-canvas-soft-2 text-sm text-ink placeholder:text-mute focus:border-ink focus:outline-none"
        placeholder={labels.searchPlaceholder}
        autocomplete="off"
        spellcheck="false"
        aria-label={labels.searchPlaceholder}
        aria-controls="ls-results"
      />
    </div>
    <ul
      id="ls-results"
      class="ls-results max-h-72 overflow-y-auto py-1 m-0 list-none"
      role="listbox"
    >
      <!-- Populated client-side: max 5 filtered suggestions. -->
    </ul>
    <p class="ls-empty hidden px-3 py-3 text-sm text-mute text-center m-0" data-empty={labels.noResults}>
      {labels.noResults}
    </p>
  </div>
</div>

<script>
  interface LangEntry {
    code: string;
    endonym: string;
    english: string;
    flag: string;
  }

  const MAX_SUGGESTIONS = 5;
  const COOKIE_MAX_AGE = 60 * 60 * 24 * 365; // 1 year

  document.querySelectorAll<HTMLElement>(".ls-root").forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>(".ls-trigger")!;
    const panel = root.querySelector<HTMLElement>(".ls-panel")!;
    const search = root.querySelector<HTMLInputElement>(".ls-search")!;
    const results = root.querySelector<HTMLUListElement>(".ls-results")!;
    const empty = root.querySelector<HTMLParagraphElement>(".ls-empty")!;

    const catalogue: LangEntry[] = JSON.parse(root.dataset.catalogue || "[]");
    const defaultLang = root.dataset.defaultLang || "en";
    const cookieName = root.dataset.cookie || "lang";
    const basePath = root.dataset.basePath || "/";

    function routeFor(code: string): string {
      const clean = basePath === "/" ? "" : basePath.replace(/^\/+/, "");
      return code === defaultLang ? `/${clean}` : `/${code}/${clean}`;
    }

    function choose(code: string) {
      document.cookie = `${cookieName}=${code}; path=/; max-age=${COOKIE_MAX_AGE}; samesite=lax`;
      window.location.assign(routeFor(code));
    }

    function render(query: string) {
      const q = query.trim().toLowerCase();
      const matches = (
        q
          ? catalogue.filter(
              (l) =>
                l.code.toLowerCase().startsWith(q) ||
                l.english.toLowerCase().includes(q) ||
                l.endonym.toLowerCase().includes(q),
            )
          : catalogue
      ).slice(0, MAX_SUGGESTIONS);

      results.innerHTML = "";
      empty.classList.toggle("hidden", matches.length > 0);

      for (const l of matches) {
        const li = document.createElement("li");
        li.setAttribute("role", "option");
        li.className =
          "flex items-center gap-3 px-3 py-2 cursor-pointer text-sm text-ink hover:bg-canvas-soft-2 focus:bg-canvas-soft-2";
        li.tabIndex = 0;
        li.innerHTML = `<span class="fi fi-${l.flag} rounded-[2px] shrink-0" aria-hidden="true"></span><span class="truncate">${l.endonym}</span><span class="ml-auto text-xs text-mute uppercase">${l.code}</span>`;
        const pick = () => choose(l.code);
        li.addEventListener("click", pick);
        li.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            pick();
          }
        });
        results.appendChild(li);
      }
    }

    function open() {
      panel.classList.remove("hidden");
      trigger.setAttribute("aria-expanded", "true");
      search.value = "";
      render("");
      search.focus();
    }

    function close() {
      panel.classList.add("hidden");
      trigger.setAttribute("aria-expanded", "false");
    }

    trigger.addEventListener("click", () => {
      panel.classList.contains("hidden") ? open() : close();
    });

    search.addEventListener("input", () => render(search.value));

    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  });
</script>
