---
import "flag-icons/css/flag-icons.min.css";
import {
  LANGUAGES,
  DEFAULT_LANG,
  LANG_BY_CODE,
  LANG_COOKIE,
  REGION_MAP,
} from "../i18n/config";

interface Props {
  lang: string;
  pathname?: string;
  labels: { label: string; searchPlaceholder: string; noResults: string; suggested?: string };
}

const { lang, pathname = "/", labels } = Astro.props;
const active = LANG_BY_CODE[lang] ?? LANG_BY_CODE[DEFAULT_LANG];

const suggestedLabel = labels.suggested ?? "Suggested for your region";

const knownPrefixes = LANGUAGES.map((l) => l.code).filter(
  (c) => c !== DEFAULT_LANG,
);
let basePath = pathname;
for (const code of knownPrefixes) {
  if (basePath === `/${code}` || basePath.startsWith(`/${code}/`)) {
    basePath = basePath.slice(code.length + 1) || "/";
    break;
  }
}

const catalogue = LANGUAGES.map((l) => ({
  code: l.code,
  endonym: l.endonym,
  english: l.englishName,
  flag: l.flag,
}));
---

<div
  class="ls-root relative"
  data-default-lang={DEFAULT_LANG}
  data-cookie={LANG_COOKIE}
  data-base-path={basePath}
  data-active-lang={lang}
  data-suggested-label={suggestedLabel}
  data-region-map={JSON.stringify(REGION_MAP)}
  data-catalogue={JSON.stringify(catalogue)}
>
  <button
    type="button"
    class="ls-trigger inline-flex items-center gap-1.5 lg:gap-2 h-9 px-2.5 lg:px-3 rounded-pill border border-hairline bg-canvas-soft-2 text-sm font-medium text-ink cursor-pointer transition-colors hover:border-hairline-strong focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-link"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label={labels.label}
  >
    <span class={`fi fi-${active.flag} rounded-[2px] shrink-0`} aria-hidden="true"></span>
    {/* Full native name on desktop; compact ISO Alpha-2 country code on mobile/tablet. */}
    <span class="ls-active-name hidden lg:inline">{active.endonym}</span>
    <span class="ls-active-code lg:hidden uppercase">{active.flag}</span>
    <svg class="w-3.5 h-3.5 text-mute shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
    </svg>
  </button>

  <div
    class="ls-panel hidden absolute right-0 mt-2 w-64 z-50 rounded-lg border border-hairline bg-canvas shadow-lg overflow-hidden"
    role="dialog"
    aria-label={labels.label}
  >
    <div class="p-2 border-b border-hairline">
      <input
        type="text"
        class="ls-search w-full h-9 px-3 rounded-md border border-hairline bg-canvas-soft-2 text-sm text-ink placeholder:text-mute focus:border-ink focus:outline-none"
        placeholder={labels.searchPlaceholder}
        autocomplete="off"
        spellcheck="false"
        aria-label={labels.searchPlaceholder}
        aria-controls="ls-results"
      />
    </div>
    <ul
      id="ls-results"
      class="ls-results max-h-72 overflow-y-auto py-1 m-0 list-none"
      role="listbox"
    >
    </ul>
    <p class="ls-empty hidden px-3 py-3 text-sm text-mute text-center m-0" data-empty={labels.noResults}>
      {labels.noResults}
    </p>
  </div>
</div>

<script>
  interface LangEntry {
    code: string;
    endonym: string;
    english: string;
    flag: string;
  }

  const MAX_SUGGESTIONS = 5;
  const COOKIE_MAX_AGE = 60 * 60 * 24 * 365;

  let docListenersAttached = false;

  function attachDocListeners(getActiveRoots: () => HTMLElement[]) {
    if (docListenersAttached) return;
    docListenersAttached = true;
    document.addEventListener("click", (e) => {
      const roots = getActiveRoots();
      if (!roots.some(r => r.contains(e.target as Node))) {
        roots.forEach(r => {
          const panel = r.querySelector<HTMLElement>(".ls-panel");
          const trigger = r.querySelector<HTMLButtonElement>(".ls-trigger");
          panel?.classList.add("hidden");
          trigger?.setAttribute("aria-expanded", "false");
        });
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        const roots = getActiveRoots();
        roots.forEach(r => {
          const panel = r.querySelector<HTMLElement>(".ls-panel");
          const trigger = r.querySelector<HTMLButtonElement>(".ls-trigger");
          panel?.classList.add("hidden");
          trigger?.setAttribute("aria-expanded", "false");
        });
      }
    });
  }

  document.querySelectorAll<HTMLElement>(".ls-root").forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>(".ls-trigger")!;
    const panel = root.querySelector<HTMLElement>(".ls-panel")!;
    const search = root.querySelector<HTMLInputElement>(".ls-search")!;
    const results = root.querySelector<HTMLUListElement>(".ls-results")!;
    const empty = root.querySelector<HTMLParagraphElement>(".ls-empty")!;

    const catalogue: LangEntry[] = JSON.parse(root.dataset.catalogue || "[]");
    const defaultLang = root.dataset.defaultLang || "en";
    const cookieName = root.dataset.cookie || "lang";
    const basePath = root.dataset.basePath || "/";
    const activeLang = root.dataset.activeLang || defaultLang;
    const suggestedLabel = root.dataset.suggestedLabel || "Suggested for your region";
    const regionMap: Record<string, string> = JSON.parse(root.dataset.regionMap || "{}");

    const byCode = (code: string): LangEntry | undefined =>
      catalogue.find((l) => l.code === code);

    let suggestedLang: string | null = null;

    async function detectRegionLang(): Promise<void> {
      try {
        const res = await fetch("/cdn-cgi/trace", { cache: "no-store" });
        if (!res.ok) return;
        const text = await res.text();
        const m = text.match(/^loc=([A-Z]{2})/m);
        const country = m?.[1];
        if (!country) return;
        const mapped = regionMap[country];
        if (mapped && mapped !== activeLang && byCode(mapped)) {
          suggestedLang = mapped;
          if (!panel.classList.contains("hidden") && search.value.trim() === "") {
            render("");
          }
        }
      } catch {}
    }

    function routeFor(code: string): string {
      const clean = basePath === "/" ? "" : basePath.replace(/^\/+/, "");
      return code === defaultLang ? `/${clean}` : `/${code}/${clean}`;
    }

    function choose(code: string) {
      document.cookie = `${cookieName}=${code}; path=/; max-age=${COOKIE_MAX_AGE}; samesite=lax; secure`;
      window.location.assign(routeFor(code));
    }

    function makeOption(l: LangEntry, suggested = false): HTMLLIElement {
      const li = document.createElement("li");
      li.setAttribute("role", "option");
      li.className =
        "flex items-center gap-3 px-3 py-2 cursor-pointer text-sm text-ink hover:bg-canvas-soft-2 focus:bg-canvas-soft-2";
      li.tabIndex = 0;
      const marker = suggested
        ? `<svg class="shrink-0 w-3.5 h-3.5 text-link" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>`
        : `<span class="fi fi-${l.flag} rounded-[2px] shrink-0" aria-hidden="true"></span>`;
      li.innerHTML =
        `${marker}<span class="truncate">${l.endonym}</span>` +
        (suggested
          ? `<span class="ml-auto text-[10px] uppercase tracking-wide text-link font-medium">${suggestedLabel}</span>`
          : `<span class="ml-auto text-xs text-mute uppercase">${l.code}</span>`);
      const pick = () => choose(l.code);
      li.addEventListener("click", pick);
      li.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          pick();
        }
      });
      return li;
    }

    function render(query: string) {
      const q = query.trim().toLowerCase();
      const matches = (
        q
          ? catalogue.filter(
              (l) =>
                l.code.toLowerCase().startsWith(q) ||
                l.english.toLowerCase().includes(q) ||
                l.endonym.toLowerCase().includes(q),
            )
          : catalogue
      ).slice(0, MAX_SUGGESTIONS);

      results.innerHTML = "";

      const suggestedEntry =
        !q && suggestedLang ? byCode(suggestedLang) : undefined;
      if (suggestedEntry) {
        results.appendChild(makeOption(suggestedEntry, true));
      }

      const shown = suggestedEntry
        ? matches.filter((l) => l.code !== suggestedEntry.code)
        : matches;

      empty.classList.toggle(
        "hidden",
        shown.length > 0 || suggestedEntry !== undefined,
      );

      for (const l of shown) {
        results.appendChild(makeOption(l));
      }
    }

    function open() {
      panel.classList.remove("hidden");
      trigger.setAttribute("aria-expanded", "true");
      search.value = "";
      render("");
      search.focus();
    }

    function close() {
      panel.classList.add("hidden");
      trigger.setAttribute("aria-expanded", "false");
    }

    trigger.addEventListener("click", () => {
      panel.classList.contains("hidden") ? open() : close();
    });

    search.addEventListener("input", () => render(search.value));

    const roots: HTMLElement[] = [];
    document.querySelectorAll<HTMLElement>(".ls-root").forEach(r => roots.push(r));
    attachDocListeners(() => roots);

    detectRegionLang();
  });
</script>
