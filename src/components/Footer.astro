---
import { getDictionary } from '../i18n/dictionaries';
import { DEFAULT_LANG } from '../i18n/config';

interface Props {
  lang?: string;
}

const { lang = DEFAULT_LANG } = Astro.props;
const dict = getDictionary(lang);
const t = dict.footer;
const nav = dict.nav;

const prefix = lang === DEFAULT_LANG ? '' : `/${lang}`;
const href = (p: string) => {
  if (p === '/') return prefix === '' ? '/' : `${prefix}/`;
  return p;
};
---

<footer class="bg-[#0a0a0a] border-t border-[#2a2a2a] mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-sm font-semibold mb-3 text-[#ededed]">{t.aboutHeading}</h3>
        <p class="text-sm text-[#a3a3a3] leading-relaxed">{t.aboutBody}</p>
      </div>

      <div>
        <h3 class="text-sm font-semibold mb-3 text-[#ededed]">{t.featuresHeading}</h3>
        <ul class="space-y-2 text-sm text-[#a3a3a3]">
          {t.features.map((f) => <li>✓ {f}</li>)}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold mb-3 text-[#ededed]">{t.greatForHeading}</h3>
        <ul class="space-y-2 text-sm text-[#a3a3a3]">
          {t.greatFor.map((g) => <li set:html={g} />)}
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-[#2a2a2a] flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[#a3a3a3]">
      <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2" aria-label="Footer">
        <a href={href('/')} class="text-[#a3a3a3] no-underline hover:text-[#ededed] transition-colors">{nav.home}</a>
        <a href={href('/about')} class="text-[#a3a3a3] no-underline hover:text-[#ededed] transition-colors">{nav.about}</a>
        <a href={href('/privacy-policy')} class="text-[#a3a3a3] no-underline hover:text-[#ededed] transition-colors">{nav.privacy}</a>
        <a href={href('/terms')} class="text-[#a3a3a3] no-underline hover:text-[#ededed] transition-colors">{nav.terms}</a>
        <a href={href('/contact')} class="text-[#a3a3a3] no-underline hover:text-[#ededed] transition-colors">{nav.contact}</a>
      </nav>
      <p class="m-0 whitespace-nowrap">&copy; {new Date().getFullYear()} FreeRemoveBG. {t.rights}</p>
    </div>
  </div>
</footer>
