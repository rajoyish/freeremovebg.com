---
interface Props {
  current: string;
}

const { current } = Astro.props;
---

<nav aria-label="Breadcrumb" class="px-6 pt-6 pb-0">
  <ol class="max-w-[760px] mx-auto flex items-center gap-2 text-sm text-mute m-0 p-0 list-none">
    <li>
      <a href="/" class="text-mute no-underline hover:text-ink transition-colors">Home</a>
    </li>
    <li aria-hidden="true" class="select-none">/</li>
    <li>
      <span class="text-ink font-medium">{current}</span>
    </li>
  </ol>
</nav>
