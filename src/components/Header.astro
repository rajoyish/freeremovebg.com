---
// Header component following Vercel design system
---

<header class="sticky top-0 z-50 bg-canvas border-b border-hairline backdrop-blur-sm bg-canvas/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="6" fill="#171717"/>
          <path d="M16 8L24 16L16 24L8 16L16 8Z" fill="white"/>
        </svg>
        <span class="text-lg font-semibold tracking-tight">FreeRemoveBG</span>
      </div>
      
      <!-- Privacy Badge -->
      <div class="flex items-center gap-2 px-3 py-1.5 bg-canvas-soft border border-hairline rounded-full">
        <svg class="w-4 h-4 text-success" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-sm font-medium text-body">100% Private - Processed Locally</span>
      </div>
    </div>
  </div>
</header>

<style>
  .bg-canvas {
    background-color: var(--color-canvas);
  }
  
  .bg-canvas\/80 {
    background-color: rgba(255, 255, 255, 0.8);
  }
  
  .bg-canvas-soft {
    background-color: var(--color-canvas-soft);
  }
  
  .border-hairline {
    border-color: var(--color-hairline);
  }
  
  .text-body {
    color: var(--color-body);
  }
  
  .text-success {
    color: var(--color-success);
  }
</style>
