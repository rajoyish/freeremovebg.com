---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getDictionary } from '../i18n/dictionaries';
import { DEFAULT_LANG, localizedUrl } from '../i18n/config';

interface Props {
  /** Active language code. */
  lang?: string;
  /** Page path WITHOUT a language prefix, e.g. "/about". */
  basePath?: string;
}

const { lang = DEFAULT_LANG, basePath = '/' } = Astro.props;
const dict = getDictionary(lang);
const t = dict.nav;

// Prefix nav hrefs with the active language so navigation stays in-locale.
const prefix = lang === DEFAULT_LANG ? '' : `/${lang}`;
const href = (p: string) => {
  if (p === '/') return prefix === '' ? '/' : `${prefix}/`;
  return `${prefix}${p}`;
};

const currentPath = (basePath.replace(/\/$/, '') || '/');

const navLinks = [
  { path: '/', label: t.home },
  { path: '/about', label: t.about },
  { path: '/privacy-policy', label: t.privacy },
  { path: '/terms', label: t.terms },
  { path: '/contact', label: t.contact },
];

function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath === path + '/';
}

// Full pathname (with prefix) for the switcher so it can preserve location.
const switcherPath = href(currentPath);
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-2 h-16">
      <a href={href('/')} class="flex items-center gap-2 no-underline min-w-0">
        <img src="/favicon.svg" alt="FreeRemoveBG logo" class="w-8 h-8 shrink-0" />
        <span class="text-lg font-semibold tracking-tight text-ink truncate">FreeRemoveBG</span>
      </a>

      <nav class="hidden md:flex items-center gap-6" aria-label="Main">
        {navLinks.map(({ path, label }) => (
          <a
            href={href(path)}
            class:list={[
              'text-sm no-underline transition-colors',
              isActive(path) ? 'font-bold text-ink' : 'text-body hover:text-ink',
            ]}
            aria-current={isActive(path) ? 'page' : undefined}
          >
            {label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2 sm:gap-3 shrink-0">
        <LanguageSwitcher
          lang={lang}
          pathname={switcherPath}
          labels={dict.switcher}
        />

        <button
          id="theme-toggle"
          type="button"
          role="switch"
          aria-label={t.toggleTheme}
          title={t.toggleTheme}
          class="relative inline-flex h-7 w-12 shrink-0 items-center rounded-full border border-hairline bg-canvas-soft-2 transition-colors duration-200 cursor-pointer hover:border-hairline-strong focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-link">
          <span class="inline-flex h-5 w-5 translate-x-1 items-center justify-center rounded-full bg-ink text-on-primary shadow-sm transition-transform duration-200 dark:translate-x-6">
            <svg class="block h-3 w-3 dark:hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
            <svg class="hidden h-3 w-3 dark:block" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="4" />
              <path stroke-linecap="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41" />
            </svg>
          </span>
        </button>

        <button
          id="mobile-menu-btn"
          type="button"
          aria-label={t.openMenu}
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-md border border-hairline bg-canvas-soft-2 cursor-pointer transition-colors hover:border-hairline-strong focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-link">
          <svg id="menu-icon-open" class="w-5 h-5 text-ink" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="hidden w-5 h-5 text-ink" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <nav id="mobile-menu" class="hidden md:hidden border-t border-hairline py-4" aria-label="Mobile">
      <ul class="flex flex-col gap-1 list-none m-0 p-0">
        {navLinks.map(({ path, label }) => (
          <li>
            <a
              href={href(path)}
              class:list={[
                'block px-3 py-2.5 text-sm no-underline rounded-md transition-colors',
                isActive(path) ? 'font-bold text-ink bg-canvas-soft-2' : 'text-body hover:bg-canvas-soft-2 hover:text-ink',
              ]}
              aria-current={isActive(path) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  function syncState() {
    const isDark = document.documentElement.classList.contains('dark');
    toggle?.setAttribute('aria-checked', String(isDark));
  }

  syncState();

  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    syncState();
  });

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
