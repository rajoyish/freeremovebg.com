---
import '../styles/global.css';
import { SITE, LANGUAGES, DEFAULT_LANG, LANG_BY_CODE, localizedUrl } from '../i18n/config';
import AdSense from '../components/AdSense.astro';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
	lang?: string;
	basePath?: string;
	localized?: boolean;
}

const {
	title = 'Free Remove BG: Free AI Background Remover Online',
	description = 'Free Remove BG is a free AI background remover. Remove bg from image, GIF and batches online in HD. 100% private, no sign-up, unlimited downloads.',
	keywords = 'free remove bg, remove bg, free ai bg remove, remove bg app image, remove bg free, remove bg from image, remove bg from gif, remove bg ai, remove bg online, remove bg background, remove bg gif, remove bg hd, remove bg high quality, background remove bg, multiple image bg remove, batch bg remove, bg remove ai, remove bg ms word, remove bg ppt, remove bg canva, remove bg web, remove bg offline',
	lang = DEFAULT_LANG,
	basePath = '/',
	localized = true,
	canonical: providedCanonical,
	ogImage = `${SITE}/images/og-frbg.png`,
	noindex = false,
} = Astro.props;

const getPagePath = () => {
  const langPrefix = lang === DEFAULT_LANG ? '' : `/${lang}`;
  let p = basePath || '/';
  if (p === '/') {
    return langPrefix || '/';
  }
  if (!p.startsWith('/')) p = `/${p}`;
  if (!p.endsWith('/')) p = `${p}/`;
  return `${langPrefix}${p}`;
};

const canonicalHref = providedCanonical
  ? new URL(providedCanonical, Astro.site).href
  : new URL(getPagePath(), Astro.site).href;

const activeLang = LANG_BY_CODE[lang] ?? LANG_BY_CODE[DEFAULT_LANG];

const hreflangAlternates = localized
	? LANGUAGES.map((l) => {
			const path = l.code === DEFAULT_LANG ? '/' : `/${l.code}/`;
			return {
				hreflang: l.code,
				href: new URL(path, Astro.site).href,
			};
		})
	: [];
const ogLocale = `${lang}_${activeLang.flag.toUpperCase()}`;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Free Remove BG',
	url: SITE,
	description,
	applicationCategory: 'MultimediaApplication',
	operatingSystem: 'Any (web browser)',
	browserRequirements: 'Requires a modern web browser with JavaScript.',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	featureList: [
		'AI background removal',
		'Remove bg from image, GIF, JPG, PNG and WebP',
		'Batch / multiple image background removal',
		'HD transparent PNG downloads',
		'100% private, on-device processing',
		'Works offline after first load',
	],
};
---

<!doctype html>
<html lang={lang} dir={activeLang.dir}>
	<head>
		<meta charset="UTF-8" />
		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && prefersDark)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
		<link rel="canonical" href={canonicalHref} />

		{hreflangAlternates.map((alt) => (
			<link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
		))}
		{localized && (
			<link rel="alternate" hreflang="x-default" href={new URL(basePath === '/' ? '/' : `/${DEFAULT_LANG}${basePath}`, Astro.site).href} />
		)}

		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="RemoveBG" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:site_name" content="Free Remove BG" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content="Free Remove BG - free AI background remover" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<AdSense />

		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}

			(function loadGA() {
				function init() {
					var s = document.createElement('script');
					s.src = 'https://www.googletagmanager.com/gtag/js?id=G-7NSS890Q9C';
					s.async = true;
					document.head.appendChild(s);
					gtag('js', new Date());
					gtag('config', 'G-7NSS890Q9C');
				}
				if ('requestIdleCallback' in window) {
					requestIdleCallback(init, { timeout: 3500 });
				} else {
					setTimeout(init, 3500);
				}
			})();
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			id="gf-stylesheet"
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap"
		/>
		<script is:inline>
			(() => {
				const l = document.getElementById('gf-stylesheet');
				if (l) l.addEventListener('load', () => { l.rel = 'stylesheet'; }, { once: true });
			})();
		</script>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
		</noscript>
	</head>
	<body>
		<slot />
	</body>
</html>
