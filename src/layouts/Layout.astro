---
import '../styles/global.css';
import { SITE, LANGUAGES, DEFAULT_LANG, LANG_BY_CODE, localizedUrl } from '../i18n/config';
import AdSense from '../components/AdSense.astro';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
	/** Active ISO 639-1 language for this page. Drives <html lang/dir> + hreflang. */
	lang?: string;
	/** Path of the page WITHOUT any language prefix, e.g. "/about" or "/". */
	basePath?: string;
	/** Whether localized variants of THIS page exist (emit hreflang alternates). */
	localized?: boolean;
}

const {
	title = 'Free Remove BG: Free AI Background Remover Online',
	description = 'Free Remove BG is a free AI background remover. Remove bg from image, GIF and batches online in HD. 100% private, no sign-up, unlimited downloads.',
	keywords = 'free remove bg, remove bg, free ai bg remove, remove bg app image, remove bg free, remove bg from image, remove bg from gif, remove bg ai, remove bg online, remove bg background, remove bg gif, remove bg hd, remove bg high quality, background remove bg, multiple image bg remove, batch bg remove, bg remove ai, remove bg ms word, remove bg ppt, remove bg canva, remove bg web, remove bg offline',
	lang = DEFAULT_LANG,
	basePath = '/',
	localized = true,
	canonical = localizedUrl(lang, basePath),
	ogImage = `${SITE}/images/og-frbg.png`,
	noindex = false,
} = Astro.props;

const activeLang = LANG_BY_CODE[lang] ?? LANG_BY_CODE[DEFAULT_LANG];

// hreflang alternates: one per supported language for THIS page, plus the
// mandatory x-default pointing at the English root so search engines know what
// to serve users who match no explicit geolocation rule. Only emitted for pages
// that actually have localized variants (the home page).
const hreflangAlternates = localized
	? LANGUAGES.map((l) => ({ hreflang: l.code, href: localizedUrl(l.code, basePath) }))
	: [];
// Open Graph requires locale as `language_TERRITORY` (e.g. en_US, hi_IN), not a
// bare language code. Derive the territory from the active language's region
// (the `flag` field is an ISO 3166-1 alpha-2 country code).
const ogLocale = `${lang}_${activeLang.flag.toUpperCase()}`;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Free Remove BG',
	url: SITE,
	description,
	applicationCategory: 'MultimediaApplication',
	operatingSystem: 'Any (web browser)',
	browserRequirements: 'Requires a modern web browser with JavaScript.',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	featureList: [
		'AI background removal',
		'Remove bg from image, GIF, JPG, PNG and WebP',
		'Batch / multiple image background removal',
		'HD transparent PNG downloads',
		'100% private, on-device processing',
		'Works offline after first load',
	],
};
---

<!doctype html>
<html lang={lang} dir={activeLang.dir}>
	<head>
		<meta charset="UTF-8" />
		<!-- Set theme before first paint to avoid a flash of the wrong theme -->
		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && prefersDark)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
		<link rel="canonical" href={canonical} />

		<!-- Localization alternates: every supported language for this page, plus
		     x-default pointing at the English root for users who match no rule. -->
		{hreflangAlternates.map((alt) => (
			<link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
		))}
		{localized && (
			<link rel="alternate" hreflang="x-default" href={localizedUrl(DEFAULT_LANG, basePath)} />
		)}

		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="RemoveBG" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="Free Remove BG" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content="Free Remove BG - free AI background remover" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Google AdSense loader. Inert until PUBLIC_ADSENSE_CLIENT is set, so
		     this ships dormant and activates with a single env var later. -->
		<AdSense />


		<!-- Google Analytics: deferred until after first paint to avoid forced-
		     reflow during the critical rendering window. The gtag.js library
		     performs DOM reads (viewport measurements, scroll offsets) on init,
		     which causes ~82 ms of layout thrashing when it races with the
		     initial render. Loading it on `requestIdleCallback` (or a 3.5 s
		     fallback) ensures it never fires before LCP completes. -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}

			(function loadGA() {
				function init() {
					var s = document.createElement('script');
					s.src = 'https://www.googletagmanager.com/gtag/js?id=G-7NSS890Q9C';
					s.async = true;
					document.head.appendChild(s);
					gtag('js', new Date());
					gtag('config', 'G-7NSS890Q9C');
				}
				if ('requestIdleCallback' in window) {
					requestIdleCallback(init, { timeout: 3500 });
				} else {
					setTimeout(init, 3500);
				}
			})();
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- Preload the Google Fonts CSS as a non-render-blocking resource, then
		     promote it to a stylesheet once loaded. The promotion is done from an
		     inline script (below) rather than an inline `onload=` attribute so the
		     Content Security Policy can stay free of `unsafe-inline`/`unsafe-hashes`
		     in script-src — inline event-handler attributes would otherwise require
		     loosening the policy. -->
		<link
			id="gf-stylesheet"
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap"
		/>
		<script is:inline>
			(() => {
				const l = document.getElementById('gf-stylesheet');
				if (l) l.addEventListener('load', () => { l.rel = 'stylesheet'; }, { once: true });
			})();
		</script>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
		</noscript>
	</head>
	<body>
		<slot />
	</body>
</html>
