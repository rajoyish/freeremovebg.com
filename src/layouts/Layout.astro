---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
}

const SITE = 'https://freeremovebg.com';

const {
	title = 'Free Remove BG: Free AI Background Remover Online',
	description = 'Free Remove BG is a free AI background remover. Remove bg from image, GIF and batches online in HD. 100% private, no sign-up, unlimited downloads.',
	keywords = 'free remove bg, remove bg, free ai bg remove, remove bg app image, remove bg free, remove bg from image, remove bg from gif, remove bg ai, remove bg online, remove bg background, remove bg gif, remove bg hd, remove bg high quality, background remove bg, multiple image bg remove, batch bg remove, bg remove ai, remove bg ms word, remove bg ppt, remove bg canva, remove bg web, remove bg offline',
	canonical = `${SITE}/`,
	ogImage = `${SITE}/images/og-frbg.png`,
	noindex = false,
} = Astro.props;

// Structured data: helps search engines understand the tool.
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Free Remove BG',
	url: SITE,
	description,
	applicationCategory: 'MultimediaApplication',
	operatingSystem: 'Any (web browser)',
	browserRequirements: 'Requires a modern web browser with JavaScript.',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	featureList: [
		'AI background removal',
		'Remove bg from image, GIF, JPG, PNG and WebP',
		'Batch / multiple image background removal',
		'HD transparent PNG downloads',
		'100% private, on-device processing',
		'Works offline after first load',
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<!-- Set theme before first paint to avoid a flash of the wrong theme -->
		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && prefersDark)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Primary SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
		<link rel="canonical" href={canonical} />

		<!-- Icons / PWA -->
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="RemoveBG" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="Free Remove BG" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content="Free Remove BG - free AI background remover" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Structured data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Google Analytics -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-7NSS890Q9C"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-7NSS890Q9C');
		</script>

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
	</head>
	<body>
		<slot />
	</body>
</html>
