---
/**
 * Localized home page: `/hi/`, `/ne/`, `/es/`, etc.
 *
 * `getStaticPaths` enumerates every target language from the central config, so
 * adding a language to `languages.json` (and generating its locale file) is all
 * it takes to produce a new fully-static localized route. No runtime work.
 */
import HomePage from '../../components/HomePage.astro';
import { TARGET_LANGUAGES } from '../../i18n/config';

export function getStaticPaths() {
  return TARGET_LANGUAGES.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
---

<HomePage lang={lang} />
