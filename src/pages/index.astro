---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">

      <!-- Hero -->
      <section class="px-6 pt-16 pb-8 text-center">
        <div class="max-w-[800px] mx-auto">
          <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-semibold tracking-[-2px] leading-[1.1] mt-0 mb-5 text-ink">
            Remove Image Backgrounds with AI.
          </h1>
          <p class="text-lg text-body leading-[1.7] mt-0 mb-8 max-w-[600px] mx-auto">
            High-quality background removal powered by AI. 100% client-side — your images never leave your device. No sign-up, unlimited HD downloads.
          </p>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-canvas-soft-2 border border-hairline rounded-pill text-[13px] text-body font-medium">
            <svg width="14" height="14" fill="none" class="stroke-link" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            100% Private — Processed Locally in Your Browser
          </div>
        </div>
      </section>

      <!-- Upload Zone -->
      <section class="px-6 pb-16">
        <div class="max-w-[960px] mx-auto">

          <!-- Model selector -->
          <div class="mb-5 flex items-center gap-3 flex-wrap">
            <span class="text-[13px] font-medium text-body">Quality:</span>
            <div id="model-selector" class="inline-flex bg-canvas-soft-2 border border-hairline rounded-md p-[3px] gap-0.5">
              <button data-model="auto"
                class="px-3.5 py-1.5 border-none rounded-sm text-[13px] font-medium cursor-pointer transition-colors bg-ink text-on-primary">
                ✦ Smart
              </button>
              <button data-model="portrait"
                class="px-3.5 py-1.5 border-none rounded-sm text-[13px] font-medium cursor-pointer transition-colors bg-transparent text-body">
                People & Portraits
              </button>
              <button data-model="general"
                class="px-3.5 py-1.5 border-none rounded-sm text-[13px] font-medium cursor-pointer transition-colors bg-transparent text-body">
                Objects & Graphics
              </button>
            </div>
            <span id="model-hint" class="text-xs text-mute italic">
              Analyses your image and automatically selects the best engine for the result
            </span>
          </div>

          <!-- Drop zone -->
          <div id="upload-zone"
            class="rounded-lg overflow-hidden border-2 border-dashed border-hairline-strong bg-canvas cursor-pointer transition-[border-color,background] duration-200 [&:not(.has-files):hover]:border-ink [&:not(.has-files):hover]:bg-canvas-soft">

            <!-- Empty state -->
            <div id="zone-empty" class="px-6 py-16 text-center">
              <svg width="48" height="48" fill="none" class="stroke-mute mx-auto mb-4 block" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              <p class="text-lg font-semibold text-ink mt-0 mb-2">Drop images here or click to upload</p>
              <p class="text-sm text-mute mt-0 mb-6">Supports JPG, PNG, WebP · Multiple files supported</p>
              <button id="browse-btn"
                class="px-6 py-2.5 bg-ink text-on-primary border-none rounded-pill text-sm font-medium cursor-pointer transition-opacity hover:opacity-[0.85]">
                Browse Files
              </button>
            </div>

            <!-- Filled state: thumbnail grid -->
            <div id="zone-filled" class="hidden p-4">
              <div id="thumb-grid" class="grid gap-2.5 mb-3 [grid-template-columns:repeat(auto-fill,minmax(100px,1fr))]"></div>
              <div class="flex items-center justify-between flex-wrap gap-2">
                <span id="zone-count" class="text-[13px] text-mute"></span>
                <button id="add-more-btn"
                  class="inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-transparent text-ink border border-hairline rounded-pill text-[13px] font-medium cursor-pointer transition-colors hover:border-ink">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                  Add more
                </button>
              </div>
            </div>

            <input type="file" id="file-input" accept="image/*" multiple class="hidden" />
          </div>

          <!-- Unified progress bar (hidden until processing starts) -->
          <div id="progress-state" class="hidden mt-5">
            <div class="bg-canvas border border-hairline rounded-[10px] px-5 py-4">
              <div class="flex items-center justify-between gap-3 mb-2.5">
                <div class="flex items-center gap-2.5 min-w-0">
                  <div id="spinner" class="shrink-0 w-4 h-4 border-2 border-hairline border-t-ink rounded-full animate-spin"></div>
                  <span id="loading-text" class="text-[13px] font-medium text-ink whitespace-nowrap overflow-hidden text-ellipsis">Processing…</span>
                </div>
                <span id="progress-text" class="shrink-0 text-[13px] text-mute tabular-nums">0 / 0</span>
              </div>
              <!-- Semantic progress bar: role + aria attributes for accessibility -->
              <div role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"
                id="progress-track"
                class="bg-canvas-soft-2 rounded-pill h-1.5 overflow-hidden">
                <div id="progress-bar"
                  class="bg-ink h-full rounded-pill w-(--progress) [--progress:0%] transition-[width] duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)]"></div>
              </div>
            </div>
          </div>

          <!-- Results grid -->
          <div id="image-grid" class="hidden mt-10">
            <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
              <h2 class="text-2xl font-semibold text-ink m-0">Processed Images</h2>
              <button id="download-all-btn"
                class="flex items-center gap-2 px-5 py-2.5 bg-ink text-on-primary border-none rounded-pill text-sm font-medium cursor-pointer transition-opacity hover:opacity-[0.85]">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                Download All (ZIP)
              </button>
            </div>
            <div id="images-container" class="grid gap-5 [grid-template-columns:repeat(auto-fill,minmax(280px,1fr))]"></div>
          </div>

        </div>
      </section>

      <!-- Features -->
      <section class="px-6 py-16 bg-canvas-soft-2 border-t border-hairline">
        <div class="max-w-[960px] mx-auto grid gap-10 [grid-template-columns:repeat(auto-fit,minmax(220px,1fr))]">
          <div class="text-center">
            <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
              <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-ink mt-0 mb-2">100% Private</h3>
            <p class="text-sm text-body leading-relaxed m-0">All processing happens in your browser. Your images never leave your device.</p>
          </div>
          <div class="text-center">
            <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
              <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-ink mt-0 mb-2">Smart Model Selection</h3>
            <p class="text-sm text-body leading-relaxed m-0">Auto mode detects people and picks the best AI model for each image automatically.</p>
          </div>
          <div class="text-center">
            <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
              <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-ink mt-0 mb-2">HD Downloads</h3>
            <p class="text-sm text-body leading-relaxed m-0">Download transparent PNGs in their original full resolution, every time.</p>
          </div>
        </div>
      </section>

    </main>

    <Footer />
  </div>
</Layout>

<script>
  import { pipeline, env } from '@huggingface/transformers';
  import { removeBackground } from '@imgly/background-removal';
  import JSZip from 'jszip';

  env.allowLocalModels  = false;
  env.allowRemoteModels = true;

  type ModelMode = 'auto' | 'portrait' | 'general';
  type ThumbStatus = 'queued' | 'analysing' | 'processing' | 'done' | 'error';

  let currentMode: ModelMode = 'auto';
  let detector: any     = null;
  let portraitPipe: any = null;

  // Accumulated queue across multiple "Add more" drops
  let allFiles: File[] = [];
  const processedImages: Array<{ name: string; blob: Blob; url: string }> = [];

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const uploadZone    = document.getElementById('upload-zone')!;
  const fileInput     = document.getElementById('file-input') as HTMLInputElement;
  const browseBtn     = document.getElementById('browse-btn')!;
  const addMoreBtn    = document.getElementById('add-more-btn')!;
  const zoneEmpty     = document.getElementById('zone-empty')!;
  const zoneFilled    = document.getElementById('zone-filled')!;
  const thumbGrid     = document.getElementById('thumb-grid')!;
  const zoneCount     = document.getElementById('zone-count')!;
  const progressState = document.getElementById('progress-state')!;
  const progressTrack = document.getElementById('progress-track')!;
  const progressBar   = document.getElementById('progress-bar') as HTMLElement;
  const progressText  = document.getElementById('progress-text')!;
  const loadingText   = document.getElementById('loading-text')!;
  const imageGrid     = document.getElementById('image-grid')!;
  const imagesContainer = document.getElementById('images-container')!;
  const downloadAllBtn  = document.getElementById('download-all-btn')!;
  const modelHint       = document.getElementById('model-hint')!;

  // ── Model selector ────────────────────────────────────────────────────────
  const HINTS: Record<ModelMode, string> = {
    auto:     'Analyses your image and automatically selects the best engine for the result',
    portrait: 'Optimised for sharp edges on hair, skin and fine detail in people',
    general:  'Optimised for logos, products, objects, animals and flat graphics',
  };

  const ACTIVE_BTN   = ['bg-ink', 'text-on-primary'];
  const INACTIVE_BTN = ['bg-transparent', 'text-body'];

  document.getElementById('model-selector')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-model]') as HTMLButtonElement | null;
    if (!btn) return;
    const mode = btn.dataset.model as ModelMode;
    currentMode = mode;
    document.querySelectorAll<HTMLButtonElement>('#model-selector button').forEach(b => {
      const active = b.dataset.model === mode;
      b.classList.remove(...(active ? INACTIVE_BTN : ACTIVE_BTN));
      b.classList.add(...(active ? ACTIVE_BTN : INACTIVE_BTN));
    });
    modelHint.textContent = HINTS[mode];
  });

  // ── Thumbnail helpers ─────────────────────────────────────────────────────
  const STATUS: Record<ThumbStatus, { bg: string; label: string }> = {
    queued:     { bg: 'bg-black/45',     label: 'Queued'      },
    analysing:  { bg: 'bg-amber-500/90', label: 'Analysing…' },
    processing: { bg: 'bg-link/90',      label: 'Processing…' },
    done:       { bg: 'bg-link/90',      label: '✓ Done'      },
    error:      { bg: 'bg-error/85',     label: '✗ Error'     },
  };
  const ALL_STATUS_BG = ['bg-black/45', 'bg-amber-500/90', 'bg-link/90', 'bg-error/85'];

  function addThumb(file: File, index: number) {
    const wrap = document.createElement('div');
    wrap.id = `thumb-${index}`;
    wrap.className = 'relative aspect-square rounded-md overflow-hidden bg-canvas-soft-2';

    const img = document.createElement('img');
    const objUrl = URL.createObjectURL(file);
    img.src = objUrl;
    img.alt = file.name;
    img.className = 'w-full h-full object-cover block';
    img.onload = () => URL.revokeObjectURL(objUrl);

    const overlay = document.createElement('div');
    overlay.id = `thumb-overlay-${index}`;
    overlay.className = 'absolute inset-0 flex items-center justify-center bg-black/45 transition-all duration-300';

    const badge = document.createElement('span');
    badge.id = `thumb-badge-${index}`;
    badge.className = 'text-[10px] font-semibold text-white tracking-wide uppercase';
    badge.textContent = 'Queued';

    overlay.appendChild(badge);
    wrap.appendChild(img);
    wrap.appendChild(overlay);
    thumbGrid.appendChild(wrap);
  }

  function setThumbStatus(index: number, status: ThumbStatus) {
    const overlay = document.getElementById(`thumb-overlay-${index}`);
    const badge   = document.getElementById(`thumb-badge-${index}`);
    if (!overlay || !badge) return;
    const s = STATUS[status];
    overlay.classList.remove(...ALL_STATUS_BG);
    overlay.classList.add(s.bg);
    badge.textContent = s.label;
    if (status === 'done') setTimeout(() => { overlay.classList.add('opacity-0'); }, 800);
  }

  // ── Show uploaded files in the zone ──────────────────────────────────────
  function showFilesInZone(files: File[], startIndex: number) {
    zoneEmpty.classList.add('hidden');
    zoneFilled.classList.remove('hidden');
    uploadZone.classList.add('has-files', 'cursor-default');
    uploadZone.classList.remove('cursor-pointer');
    files.forEach((f, i) => addThumb(f, startIndex + i));
    zoneCount.textContent = `${allFiles.length} image${allFiles.length !== 1 ? 's' : ''} selected`;
  }

  // ── Progress helpers ──────────────────────────────────────────────────────
  function setProgress(done: number, total: number, msg: string) {
    const pct = total > 0 ? Math.round((done / total) * 100) : 0;
    // The bar consumes this custom property via the `w-(--progress)` utility.
    progressBar.style.setProperty('--progress', `${pct}%`);
    progressTrack.setAttribute('aria-valuenow', String(pct));
    progressText.textContent = `${done} / ${total}`;
    loadingText.textContent  = msg;
  }

  // ── Lazy model loaders ────────────────────────────────────────────────────
  async function ensureDetector() {
    if (detector) return;
    loadingText.textContent = 'Preparing smart detection…';
    detector = await pipeline('object-detection', 'Xenova/detr-resnet-50', { dtype: 'fp32' });
  }

  async function ensurePortraitPipe() {
    if (portraitPipe) return;
    loadingText.textContent = 'Loading portrait engine…';
    portraitPipe = await pipeline('background-removal', 'Xenova/modnet', { dtype: 'fp32' });
  }

  async function containsPerson(objectUrl: string): Promise<boolean> {
    await ensureDetector();
    const dets = await detector(objectUrl, { threshold: 0.5 }) as Array<{ label: string }>;
    return dets.some(d => d.label.toLowerCase() === 'person');
  }

  // ── Core removal ──────────────────────────────────────────────────────────
  async function removeBg(file: File, objectUrl: string, idx: number): Promise<{ blob: Blob; usedModel: string }> {
    if (currentMode === 'portrait') {
      await ensurePortraitPipe();
      setThumbStatus(idx, 'processing');
      loadingText.textContent = 'Removing background…';
      const output = await portraitPipe(objectUrl);
      return { blob: await output.toBlob('image/png'), usedModel: 'People & Portraits' };
    }
    if (currentMode === 'general') {
      setThumbStatus(idx, 'processing');
      loadingText.textContent = 'Removing background…';
      const blob = await removeBackground(file, { model: 'medium', output: { format: 'image/png', quality: 1 } });
      return { blob, usedModel: 'Objects & Graphics' };
    }
    // Auto
    setThumbStatus(idx, 'analysing');
    loadingText.textContent = 'Analysing image…';
    const hasPerson = await containsPerson(objectUrl);
    setThumbStatus(idx, 'processing');
    loadingText.textContent = 'Removing background…';
    if (hasPerson) {
      await ensurePortraitPipe();
      const output = await portraitPipe(objectUrl);
      return { blob: await output.toBlob('image/png'), usedModel: 'Smart · People & Portraits' };
    }
    const blob = await removeBackground(file, { model: 'medium', output: { format: 'image/png', quality: 1 } });
    return { blob, usedModel: 'Smart · Objects & Graphics' };
  }

  // ── Process one image ─────────────────────────────────────────────────────
  async function processImage(file: File, thumbIdx: number): Promise<void> {
    const originalUrl = URL.createObjectURL(file);
    try {
      const { blob, usedModel } = await removeBg(file, originalUrl, thumbIdx);
      const resultUrl = URL.createObjectURL(blob);
      const name = file.name.replace(/\.[^/.]+$/, '') + '_nobg.png';
      processedImages.push({ name, blob, url: resultUrl });
      addCard(name, originalUrl, resultUrl, usedModel);
      setThumbStatus(thumbIdx, 'done');
    } catch (err) {
      URL.revokeObjectURL(originalUrl);
      setThumbStatus(thumbIdx, 'error');
      throw err;
    }
  }

  // ── Result card ───────────────────────────────────────────────────────────
  function addCard(name: string, originalUrl: string, processedUrl: string, modelLabel: string) {
    const card = document.createElement('div');
    card.className = 'bg-canvas border border-hairline rounded-[10px] overflow-hidden shadow-sm';
    card.innerHTML = `
      <div class="relative aspect-[4/3] grid grid-cols-2">
        <div class="relative overflow-hidden border-r border-hairline">
          <img src="${originalUrl}" alt="Original" class="w-full h-full object-cover block" />
          <span class="absolute top-2 left-2 px-2 py-[3px] bg-ink text-on-primary text-[11px] font-medium rounded-[4px]">Original</span>
        </div>
        <div class="relative overflow-hidden bg-checkerboard">
          <img src="${processedUrl}" alt="Background removed" class="w-full h-full object-cover block" />
          <span class="absolute top-2 right-2 px-2 py-[3px] bg-link text-white text-[11px] font-medium rounded-[4px]">Removed</span>
        </div>
      </div>
      <div class="px-4 pt-3 pb-3.5 border-t border-canvas-soft-2">
        <div class="flex items-center justify-between gap-3 mb-2">
          <p class="text-[13px] font-medium text-ink m-0 overflow-hidden text-ellipsis whitespace-nowrap flex-1">${name}</p>
          <button class="dl-btn shrink-0 px-4 py-[7px] bg-ink text-on-primary border-none rounded-pill text-[13px] font-medium cursor-pointer transition-opacity hover:opacity-80">
            Download PNG
          </button>
        </div>
        <p class="m-0 text-[11px] text-mute font-mono">
          <span class="inline-block w-[7px] h-[7px] rounded-full bg-link mr-[5px] align-middle"></span>
          ${modelLabel}
        </p>
      </div>
    `;
    imagesContainer.appendChild(card);
    imageGrid.classList.remove('hidden');
    (card.querySelector('.dl-btn') as HTMLButtonElement).addEventListener('click', () => {
      const a = document.createElement('a');
      a.href = processedUrl;
      a.download = name;
      a.click();
    });
  }

  // ── Main handler ──────────────────────────────────────────────────────────
  async function handleFiles(newFiles: File[]) {
    const imgs = newFiles.filter(f => f.type.startsWith('image/'));
    if (!imgs.length) { alert('Please select image files (JPG, PNG, WebP).'); return; }

    const startIndex = allFiles.length;
    allFiles.push(...imgs);
    showFilesInZone(imgs, startIndex);

    progressState.classList.remove('hidden');
    let doneCount = processedImages.length;
    const total   = allFiles.length;
    setProgress(doneCount, total, 'Starting…');

    for (let i = 0; i < imgs.length; i++) {
      setProgress(doneCount, total, `Processing ${imgs[i].name}…`);
      try {
        await processImage(imgs[i], startIndex + i);
      } catch (err) {
        console.error(`Skipping ${imgs[i].name}:`, err);
      }
      doneCount++;
      setProgress(doneCount, total, doneCount === total ? 'All done!' : 'Processing…');
    }

    if (doneCount === total) setTimeout(() => { progressState.classList.add('hidden'); }, 2000);
  }

  // ── ZIP download ──────────────────────────────────────────────────────────
  async function downloadZip() {
    if (!processedImages.length) return;
    const zip = new JSZip();
    processedImages.forEach(({ name, blob }) => zip.file(name, blob));
    const zipBlob = await zip.generateAsync({ type: 'blob' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(zipBlob);
    a.download = 'removed-backgrounds.zip';
    a.click();
  }

  // ── Event wiring ──────────────────────────────────────────────────────────
  const DRAG_ON  = ['border-ink', 'bg-canvas-soft'];
  const DRAG_OFF = ['border-hairline-strong', 'bg-canvas'];

  function setDragState(active: boolean) {
    uploadZone.classList.remove(...(active ? DRAG_OFF : DRAG_ON));
    uploadZone.classList.add(...(active ? DRAG_ON : DRAG_OFF));
  }

  uploadZone.addEventListener('click', () => {
    if (!uploadZone.classList.contains('has-files')) fileInput.click();
  });
  browseBtn.addEventListener('click',  (e) => { e.stopPropagation(); fileInput.click(); });
  addMoreBtn.addEventListener('click', (e) => { e.stopPropagation(); fileInput.click(); });
  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) handleFiles(Array.from(fileInput.files));
    fileInput.value = '';
  });
  uploadZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    if (!uploadZone.classList.contains('has-files')) setDragState(true);
  });
  uploadZone.addEventListener('dragleave', () => {
    if (!uploadZone.classList.contains('has-files')) setDragState(false);
  });
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    if (!uploadZone.classList.contains('has-files')) setDragState(false);
    if (e.dataTransfer?.files.length) handleFiles(Array.from(e.dataTransfer.files));
  });
  downloadAllBtn.addEventListener('click', downloadZip);
</script>
