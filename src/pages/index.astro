---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">

      <!-- Hero -->
      <section class="px-6 pt-16 pb-8 text-center">
        <div class="max-w-[800px] mx-auto">
          <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-semibold tracking-[-2px] leading-[1.1] mt-0 mb-5 text-ink">
            Remove Image Backgrounds with AI.
          </h1>
          <p class="text-lg text-body leading-[1.7] mt-0 mb-8 max-w-[600px] mx-auto">
            High-quality background removal powered by AI. Everything runs on your device, so your images never leave your browser. No sign-up, and unlimited HD downloads.
          </p>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-canvas-soft-2 border border-hairline rounded-pill text-[13px] text-body font-medium">
            <svg width="14" height="14" fill="none" class="stroke-link" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            100% Private. Processed Locally in Your Browser
          </div>
        </div>
      </section>

      <!-- Upload Zone -->
      <section class="px-6 pb-16">
        <div class="max-w-[960px] mx-auto">

          <!-- Model selector -->
          <div class="mb-5 flex items-center gap-3 flex-wrap">
            <span class="text-[13px] font-medium text-body">Quality:</span>
            <div id="model-selector" class="inline-flex bg-canvas-soft-2 border border-hairline rounded-md p-[3px] gap-0.5">
              <button data-model="auto"
                class="px-3.5 py-1.5 border-none rounded-sm text-[13px] font-medium cursor-pointer transition-colors bg-ink text-on-primary">
                ✦ Smart
              </button>
              <button data-model="portrait"
                class="px-3.5 py-1.5 border-none rounded-sm text-[13px] font-medium cursor-pointer transition-colors bg-transparent text-body">
                People & Portraits
              </button>
              <button data-model="general"
                class="px-3.5 py-1.5 border-none rounded-sm text-[13px] font-medium cursor-pointer transition-colors bg-transparent text-body">
                Objects & Graphics
              </button>
            </div>
            <span id="model-hint" class="text-xs text-mute italic">
              Analyses your image and automatically selects the best engine for the result
            </span>
          </div>

          <!-- Drop zone -->
          <div id="upload-zone"
            class="rounded-lg overflow-hidden border-2 border-dashed border-hairline-strong bg-canvas cursor-pointer transition-[border-color,background] duration-200 [&:not(.has-files):hover]:border-ink [&:not(.has-files):hover]:bg-canvas-soft">

            <!-- Empty state -->
            <div id="zone-empty" class="px-6 py-16 text-center">
              <svg width="48" height="48" fill="none" class="stroke-mute mx-auto mb-4 block" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              <p class="text-lg font-semibold text-ink mt-0 mb-2">Drop images here or click to upload</p>
              <p class="text-sm text-mute mt-0 mb-6">Supports JPG, PNG, WebP, GIF, BMP, AVIF and more · Multiple files supported</p>
              <button id="browse-btn"
                class="px-6 py-2.5 bg-ink text-on-primary border-none rounded-pill text-sm font-medium cursor-pointer transition-opacity hover:opacity-[0.85]">
                Browse Files
              </button>
            </div>

            <!-- Filled state: thumbnail grid -->
            <div id="zone-filled" class="hidden p-4">
              <div id="thumb-grid" class="grid gap-2.5 mb-3 [grid-template-columns:repeat(auto-fill,minmax(100px,1fr))]"></div>
              <div class="flex items-center justify-between flex-wrap gap-2">
                <span id="zone-count" class="text-[13px] text-mute"></span>
                <button id="add-more-btn"
                  class="inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-transparent text-ink border border-hairline rounded-pill text-[13px] font-medium cursor-pointer transition-colors hover:border-ink">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                  Add more
                </button>
              </div>
            </div>

            <input type="file" id="file-input" accept="image/*,.jpg,.jpeg,.png,.webp,.gif,.bmp,.avif,.svg,.ico,.tif,.tiff" multiple class="hidden" />
          </div>

          <!-- Unified progress bar (hidden until processing starts) -->
          <div id="progress-state" class="hidden mt-5">
            <div class="bg-canvas border border-hairline rounded-[10px] px-5 py-4">
              <div class="flex items-center justify-between gap-3 mb-2.5">
                <div class="flex items-center gap-2.5 min-w-0">
                  <div id="spinner" class="shrink-0 w-4 h-4 border-2 border-hairline border-t-ink rounded-full animate-spin"></div>
                  <span id="loading-text" class="text-[13px] font-medium text-ink whitespace-nowrap overflow-hidden text-ellipsis">Processing…</span>
                </div>
                <span id="progress-text" class="shrink-0 text-[13px] text-mute tabular-nums">0 / 0</span>
              </div>
              <!-- Semantic progress bar: role + aria attributes for accessibility -->
              <div role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"
                id="progress-track"
                class="bg-canvas-soft-2 rounded-pill h-1.5 overflow-hidden">
                <div id="progress-bar"
                  class="bg-ink h-full rounded-pill w-(--progress) [--progress:0%] transition-[width] duration-[400ms] ease-[cubic-bezier(.4,0,.2,1)]"></div>
              </div>
            </div>
          </div>

          <!-- Results grid -->
          <div id="image-grid" class="hidden mt-10">
            <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
              <h2 class="text-2xl font-semibold text-ink m-0">Processed Images</h2>
              <button id="download-all-btn"
                class="flex items-center gap-2 px-5 py-2.5 bg-ink text-on-primary border-none rounded-pill text-sm font-medium cursor-pointer transition-opacity hover:opacity-[0.85]">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                Download All (ZIP)
              </button>
            </div>
            <div id="images-container" class="grid gap-5 [grid-template-columns:repeat(auto-fill,minmax(280px,1fr))]"></div>
          </div>

        </div>
      </section>

      <!-- Features -->
      <section class="px-6 py-16 bg-canvas-soft-2 border-t border-hairline">
        <div class="max-w-[1000px] mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-[clamp(1.5rem,4vw,2.25rem)] font-semibold tracking-[-1px] text-ink mt-0 mb-3">Everything you need to cut out backgrounds</h2>
            <p class="text-base text-body leading-relaxed max-w-[600px] mx-auto m-0">A complete background removal toolkit that runs entirely on your device. It's fast, free, and built for real work.</p>
          </div>
          <div class="grid gap-x-10 gap-y-12 [grid-template-columns:repeat(auto-fit,minmax(240px,1fr))]">
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">100% Free & Completely Private</h3>
              <p class="text-sm text-body leading-relaxed m-0">Every cutout is completely free and happens directly in your browser. There are no uploads and no servers, so your images never leave your device.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">Smart Model Selection</h3>
              <p class="text-sm text-body leading-relaxed m-0">Auto mode detects people and picks the best AI model for each image, so every cutout looks its sharpest.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">HD Downloads</h3>
              <p class="text-sm text-body leading-relaxed m-0">Export transparent PNGs at their original full resolution every time. There's no quality loss and no upscaling tricks.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 6v12a2 2 0 002 2h12a2 2 0 002-2V6M9 10h6m-6 4h6"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">Batch Processing</h3>
              <p class="text-sm text-body leading-relaxed m-0">Drop in dozens of images at once and download the whole set as a single ZIP when they're done.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 17.5V19a2 2 0 002 2h14a2 2 0 002-2v-1.5"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">No Sign-Up, No Limits</h3>
              <p class="text-sm text-body leading-relaxed m-0">No account, no watermarks, no credit system. Open the page and start removing backgrounds instantly.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 001-9.9A6 6 0 105 13"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">Works Offline</h3>
              <p class="text-sm text-body leading-relaxed m-0">After the first load the AI runs locally, so you can keep cutting out backgrounds even without a connection.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h6m-6 8l-3 1 1-4A8 8 0 1120 12a8 8 0 01-9.5 7.9L7 20z"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">Crisp Edge Detail</h3>
              <p class="text-sm text-body leading-relaxed m-0">A dedicated portrait engine preserves fine strands of hair, fur, and soft edges that simple cutout tools miss.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">Any Device, Any Format</h3>
              <p class="text-sm text-body leading-relaxed m-0">Upload JPG, PNG, or WebP from desktop, tablet, or phone. The interface adapts to whatever screen you're on.</p>
            </div>
            <div class="text-center">
              <div class="w-11 h-11 bg-ink rounded-[10px] flex items-center justify-center mx-auto mb-3.5">
                <svg width="22" height="22" fill="none" class="stroke-on-primary" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="text-base font-semibold text-ink mt-0 mb-2">Instant Side-by-Side</h3>
              <p class="text-sm text-body leading-relaxed m-0">Compare the original and the cutout the moment processing finishes, on a transparency checkerboard preview.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- SEO Article (scroll-reveal) -->
      <section class="px-6 py-20 border-t border-hairline">
        <article id="seo-article" class="max-w-[760px] mx-auto">
          <div class="reveal" data-reveal>
            <h2 class="text-[clamp(1.6rem,4vw,2.4rem)] font-semibold tracking-[-1px] leading-tight text-ink mt-0 mb-5">Free Online Background Remover: Erase Image Backgrounds in Seconds</h2>
            <p class="text-base text-body leading-[1.8] m-0">FreeRemoveBG is a free, browser-based tool that removes the background from any photo automatically. Whether you need a clean transparent cutout for a product listing, a profile picture, a logo, or a design mockup, just drag in an image and get a polished result in seconds. There's no sign-up, no watermark, and nothing is uploaded to a remote server.</p>
          </div>

          <div class="reveal mt-12" data-reveal>
            <h3 class="text-[1.3rem] font-semibold text-ink mt-0 mb-4">Your Images Never Leave Your Device</h3>
            <p class="text-base text-body leading-[1.8] m-0">Most background removers send your photos to a cloud server for processing. FreeRemoveBG does the opposite, running the entire cutout locally right inside your browser. Your images are never uploaded, stored, or seen by anyone, which makes this an ideal choice for sensitive product shots, client work, personal photos, and anything you'd rather keep off the internet. Once the page has loaded, you can even disconnect from the network and keep working.</p>
          </div>

          <div class="reveal mt-12" data-reveal>
            <h3 class="text-[1.3rem] font-semibold text-ink mt-0 mb-4">Smart AI That Picks the Right Engine</h3>
            <p class="text-base text-body leading-[1.8] m-0">Different images need different handling. A portrait with flyaway hair calls for fine matting, while a hard-edged logo or product needs crisp, clean lines. Smart mode analyses each image and automatically routes it to the best engine, using a portrait-optimised model for people and a general-purpose model for objects, graphics, and animals. Prefer to decide yourself? Switch the quality selector to People &amp; Portraits or Objects &amp; Graphics at any time.</p>
          </div>

          <div class="reveal mt-12" data-reveal>
            <h3 class="text-[1.3rem] font-semibold text-ink mt-0 mb-4">How to Remove a Background</h3>
            <p class="text-base text-body leading-[1.8] m-0">Using the tool takes three steps. First, drag your image onto the upload zone or click to browse, and you can add several files at once. Second, the AI detects the subject and erases everything behind it, showing a live before-and-after preview on a transparency checkerboard. Third, download your cutout as a full-resolution transparent PNG, or grab the entire batch as a single ZIP file. There's no queue, no processing credits, and no limit on how many images you run.</p>
          </div>

          <div class="reveal mt-12" data-reveal>
            <h3 class="text-[1.3rem] font-semibold text-ink mt-0 mb-4">Who Uses a Free Background Remover?</h3>
            <p class="text-base text-body leading-[1.8] m-0">Online sellers create clean white-background product photos for marketplaces. Designers and marketers extract subjects for banners, thumbnails, and social posts. Photographers prepare cutouts for compositing and retouching. Students and teachers build presentations and worksheets, and everyday users make transparent stickers, profile pictures, and avatars. Because everything is free and unlimited, it works just as well for a single quick edit as it does for a folder full of catalogue images.</p>
          </div>

          <div class="reveal mt-12" data-reveal>
            <h3 class="text-[1.3rem] font-semibold text-ink mt-0 mb-4">Free, Unlimited, and Watermark-Free</h3>
            <p class="text-base text-body leading-[1.8] m-0">There's no paywall hiding the good output and no stamp across your downloads. Every cutout comes out at the original resolution you uploaded, completely free to use for personal and commercial projects alike. Calibrate nothing, install nothing, and sign up for nothing. Open the page and your background remover is ready the moment you need it.</p>
          </div>
        </article>
      </section>

    </main>

    <Footer />
  </div>
</Layout>

<script>
  import { pipeline, env } from '@huggingface/transformers';
  import { removeBackground } from '@imgly/background-removal';
  import * as ort from 'onnxruntime-web';
  import JSZip from 'jszip';

  env.allowLocalModels  = false;
  env.allowRemoteModels = true;

  // ── Force single-threaded ONNX Runtime ──────────────────────────────────────
  // onnxruntime-web defaults numThreads to navigator.hardwareConcurrency. Multi-
  // threaded WASM needs SharedArrayBuffer, which is only available when the page
  // is cross-origin isolated (COOP/COEP). This static site is not isolated, so
  // the threaded path silently falls back and races, producing corrupted output
  // (torn horizontal bands in the result). Pinning to a single thread makes
  // every cutout deterministic and correct. Both @imgly/background-removal and
  // @huggingface/transformers share this same ort module instance.
  //
  // imgly re-assigns numThreads (to navigator.hardwareConcurrency) at session
  // creation time, which would clobber a plain assignment. We instead lock the
  // property so any later write of a value > 1 is forced back down to 1.
  try {
    let threads = 1;
    Object.defineProperty(ort.env.wasm, 'numThreads', {
      configurable: true,
      enumerable: true,
      get: () => threads,
      set: (v: number) => { threads = (typeof v === 'number' && v > 0) ? Math.min(v, 1) : 1; },
    });
  } catch {
    ort.env.wasm.numThreads = 1;
  }
  ort.env.wasm.proxy = false;
  // Mirror the setting on the transformers backend for its own session creation.
  if (env.backends?.onnx?.wasm) {
    env.backends.onnx.wasm.numThreads = 1;
  }

  type ModelMode = 'auto' | 'portrait' | 'general';
  type ThumbStatus = 'queued' | 'analysing' | 'processing' | 'done' | 'error';

  let currentMode: ModelMode = 'auto';
  let detector: any     = null;
  let portraitPipe: any = null;

  // Accumulated queue across multiple "Add more" drops. Each item carries a
  // stable id so thumbnails and result cards stay correctly linked even after
  // the user removes images from the zone (array indices would shift and break).
  interface QueueItem {
    id: string;
    file: File;
    status: ThumbStatus;
    originalUrl?: string;
    resultUrl?: string;
    outName?: string;
    blob?: Blob;
    cardEl?: HTMLElement;
  }
  let queue: QueueItem[] = [];
  let idCounter = 0;
  const nextId = () => `img-${++idCounter}`;
  const usedNames = new Set<string>();

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const uploadZone    = document.getElementById('upload-zone')!;
  const fileInput     = document.getElementById('file-input') as HTMLInputElement;
  const browseBtn     = document.getElementById('browse-btn')!;
  const addMoreBtn    = document.getElementById('add-more-btn')!;
  const zoneEmpty     = document.getElementById('zone-empty')!;
  const zoneFilled    = document.getElementById('zone-filled')!;
  const thumbGrid     = document.getElementById('thumb-grid')!;
  const zoneCount     = document.getElementById('zone-count')!;
  const progressState = document.getElementById('progress-state')!;
  const progressTrack = document.getElementById('progress-track')!;
  const progressBar   = document.getElementById('progress-bar') as HTMLElement;
  const progressText  = document.getElementById('progress-text')!;
  const loadingText   = document.getElementById('loading-text')!;
  const imageGrid     = document.getElementById('image-grid')!;
  const imagesContainer = document.getElementById('images-container')!;
  const downloadAllBtn  = document.getElementById('download-all-btn')!;
  const modelHint       = document.getElementById('model-hint')!;

  // ── Model selector ────────────────────────────────────────────────────────
  const HINTS: Record<ModelMode, string> = {
    auto:     'Analyses your image and automatically selects the best engine for the result',
    portrait: 'Optimised for sharp edges on hair, skin and fine detail in people',
    general:  'Optimised for logos, products, objects, animals and flat graphics',
  };

  const ACTIVE_BTN   = ['bg-ink', 'text-on-primary'];
  const INACTIVE_BTN = ['bg-transparent', 'text-body'];

  document.getElementById('model-selector')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-model]') as HTMLButtonElement | null;
    if (!btn) return;
    const mode = btn.dataset.model as ModelMode;
    currentMode = mode;
    document.querySelectorAll<HTMLButtonElement>('#model-selector button').forEach(b => {
      const active = b.dataset.model === mode;
      b.classList.remove(...(active ? INACTIVE_BTN : ACTIVE_BTN));
      b.classList.add(...(active ? ACTIVE_BTN : INACTIVE_BTN));
    });
    modelHint.textContent = HINTS[mode];
  });

  // ── Thumbnail helpers ─────────────────────────────────────────────────────
  const STATUS: Record<ThumbStatus, { bg: string; label: string }> = {
    queued:     { bg: 'bg-black/45',     label: 'Queued'      },
    analysing:  { bg: 'bg-amber-500/90', label: 'Analysing…' },
    processing: { bg: 'bg-link/90',      label: 'Processing…' },
    done:       { bg: 'bg-link/90',      label: '✓ Done'      },
    error:      { bg: 'bg-error/85',     label: '✗ Error'     },
  };
  const ALL_STATUS_BG = ['bg-black/45', 'bg-amber-500/90', 'bg-link/90', 'bg-error/85'];

  // An image can only be removed while it is still waiting in the queue or has
  // errored out. Once it is analysing/processing or already done, the remove
  // control is hidden (there is no point removing a finished cutout).
  function isRemovable(status: ThumbStatus): boolean {
    return status === 'queued' || status === 'error';
  }

  function addThumb(item: QueueItem) {
    const wrap = document.createElement('div');
    wrap.id = `thumb-${item.id}`;
    wrap.className = 'relative aspect-square rounded-md overflow-hidden bg-canvas-soft-2';

    const img = document.createElement('img');
    const objUrl = URL.createObjectURL(item.file);
    img.src = objUrl;
    img.alt = item.file.name;
    img.className = 'w-full h-full object-cover block';
    img.onload = () => URL.revokeObjectURL(objUrl);

    const overlay = document.createElement('div');
    overlay.id = `thumb-overlay-${item.id}`;
    overlay.className = 'absolute inset-0 flex items-center justify-center bg-black/45 transition-all duration-300';

    const badge = document.createElement('span');
    badge.id = `thumb-badge-${item.id}`;
    badge.className = 'text-[10px] font-semibold text-white tracking-wide uppercase';
    badge.textContent = STATUS[item.status].label;

    // Remove button (top-right). Always visible while the image is removable
    // (queued or errored) so users can drop it before it is processed.
    const removeBtn = document.createElement('button');
    removeBtn.id = `thumb-remove-${item.id}`;
    removeBtn.type = 'button';
    removeBtn.setAttribute('aria-label', `Remove ${item.file.name}`);
    removeBtn.title = 'Remove image';
    removeBtn.className = 'absolute top-1 right-1 z-10 flex items-center justify-center w-6 h-6 rounded-full bg-error text-white shadow-sm transition-opacity duration-150 cursor-pointer hover:opacity-85 focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-white';
    removeBtn.innerHTML = '<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"/></svg>';
    removeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      removeItem(item.id);
    });
    if (!isRemovable(item.status)) removeBtn.classList.add('hidden');

    overlay.appendChild(badge);
    wrap.appendChild(img);
    wrap.appendChild(overlay);
    wrap.appendChild(removeBtn);
    thumbGrid.appendChild(wrap);
  }

  function setThumbStatus(id: string, status: ThumbStatus) {
    const item = queue.find(q => q.id === id);
    if (item) item.status = status;
    const overlay = document.getElementById(`thumb-overlay-${id}`);
    const badge   = document.getElementById(`thumb-badge-${id}`);
    // Show the remove control only while the image is still removable.
    document.getElementById(`thumb-remove-${id}`)?.classList.toggle('hidden', !isRemovable(status));
    if (!overlay || !badge) return;
    const s = STATUS[status];
    overlay.classList.remove(...ALL_STATUS_BG, 'opacity-0');
    overlay.classList.add(s.bg);
    badge.textContent = s.label;
    if (status === 'done') setTimeout(() => { overlay.classList.add('opacity-0'); }, 800);
  }

  // ── Remove an item from the zone ────────────────────────────────────────────
  // Only queued or errored images can be removed. The state is updated instantly
  // so the action feels immediate, while the thumbnail plays a quick scale/fade
  // collapse before being detached from the DOM.
  function removeItem(id: string) {
    const idx = queue.findIndex(q => q.id === id);
    if (idx === -1) return;
    const item = queue[idx];
    if (!isRemovable(item.status)) return; // guard: never remove while processing or done

    // Free resources and update state immediately (feels instant).
    if (item.originalUrl) URL.revokeObjectURL(item.originalUrl);
    if (item.resultUrl)   URL.revokeObjectURL(item.resultUrl);
    if (item.outName)     usedNames.delete(item.outName);
    item.cardEl?.remove();
    queue.splice(idx, 1);

    if (queue.length === 0) {
      // Animate the last thumb out, then reset the zone once it's gone.
      animateThumbOut(id, resetZone);
    } else {
      zoneCount.textContent = `${queue.length} image${queue.length !== 1 ? 's' : ''} selected`;
      if (!queue.some(q => q.resultUrl)) imageGrid.classList.add('hidden');
      animateThumbOut(id);
    }
  }

  // Play a short collapse animation on a thumbnail, then remove it from the DOM.
  function animateThumbOut(id: string, done?: () => void) {
    const el = document.getElementById(`thumb-${id}`);
    if (!el) { done?.(); return; }
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) { el.remove(); done?.(); return; }

    el.classList.add('thumb-removing');
    let finished = false;
    const finish = () => {
      if (finished) return;
      finished = true;
      el.remove();
      done?.();
    };
    el.addEventListener('transitionend', finish, { once: true });
    // Fallback in case transitionend doesn't fire (e.g. element already detached).
    setTimeout(finish, 260);
  }

  // Reset the drop zone back to its initial empty state.
  function resetZone() {
    thumbGrid.innerHTML = '';
    imagesContainer.innerHTML = '';
    zoneFilled.classList.add('hidden');
    zoneEmpty.classList.remove('hidden');
    imageGrid.classList.add('hidden');
    progressState.classList.add('hidden');
    uploadZone.classList.remove('has-files', 'cursor-default');
    uploadZone.classList.add('cursor-pointer');
    zoneCount.textContent = '';
  }

  // ── Show uploaded files in the zone ──────────────────────────────────────
  function showFilesInZone(items: QueueItem[]) {
    zoneEmpty.classList.add('hidden');
    zoneFilled.classList.remove('hidden');
    uploadZone.classList.add('has-files', 'cursor-default');
    uploadZone.classList.remove('cursor-pointer');
    items.forEach(addThumb);
    zoneCount.textContent = `${queue.length} image${queue.length !== 1 ? 's' : ''} selected`;
  }

  // ── Progress helpers ──────────────────────────────────────────────────────
  function setProgress(done: number, total: number, msg: string) {
    const pct = total > 0 ? Math.round((done / total) * 100) : 0;
    // The bar consumes this custom property via the `w-(--progress)` utility.
    progressBar.style.setProperty('--progress', `${pct}%`);
    progressTrack.setAttribute('aria-valuenow', String(pct));
    progressText.textContent = `${done} / ${total}`;
    loadingText.textContent  = msg;
  }

  // ── Lazy model loaders ────────────────────────────────────────────────────
  async function ensureDetector() {
    if (detector) return;
    loadingText.textContent = 'Preparing smart detection…';
    detector = await pipeline('object-detection', 'Xenova/detr-resnet-50', { dtype: 'fp32' });
  }

  async function ensurePortraitPipe() {
    if (portraitPipe) return;
    loadingText.textContent = 'Loading portrait engine…';
    portraitPipe = await pipeline('background-removal', 'Xenova/modnet', { dtype: 'fp32' });
  }

  async function containsPerson(objectUrl: string): Promise<boolean> {
    await ensureDetector();
    const dets = await detector(objectUrl, { threshold: 0.5 }) as Array<{ label: string }>;
    return dets.some(d => d.label.toLowerCase() === 'person');
  }

  // ── Core removal ──────────────────────────────────────────────────────────
  async function removeBg(file: Blob, objectUrl: string, id: string): Promise<{ blob: Blob; usedModel: string }> {
    if (currentMode === 'portrait') {
      await ensurePortraitPipe();
      setThumbStatus(id, 'processing');
      loadingText.textContent = 'Removing background…';
      const output = await portraitPipe(objectUrl);
      return { blob: await output.toBlob('image/png'), usedModel: 'People & Portraits' };
    }
    if (currentMode === 'general') {
      setThumbStatus(id, 'processing');
      loadingText.textContent = 'Removing background…';
      const blob = await removeBackground(file, { model: 'isnet_fp16', output: { format: 'image/png', quality: 1 } });
      return { blob, usedModel: 'Objects & Graphics' };
    }
    // Auto
    setThumbStatus(id, 'analysing');
    loadingText.textContent = 'Analysing image…';
    const hasPerson = await containsPerson(objectUrl);
    setThumbStatus(id, 'processing');
    loadingText.textContent = 'Removing background…';
    if (hasPerson) {
      await ensurePortraitPipe();
      const output = await portraitPipe(objectUrl);
      return { blob: await output.toBlob('image/png'), usedModel: 'Smart · People & Portraits' };
    }
    const blob = await removeBackground(file, { model: 'isnet_fp16', output: { format: 'image/png', quality: 1 } });
    return { blob, usedModel: 'Smart · Objects & Graphics' };
  }

  // ── Image normalisation ─────────────────────────────────────────────────────
  // Some formats (notably certain WebP files) fail to decode consistently inside
  // the AI engines, which both rely on createImageBitmap. To make every upload
  // work, we first decode the file with the browser's most tolerant decoder (an
  // <img> element) and re-encode it to a lossless PNG that the engines accept.
  async function normalizeToPng(file: File): Promise<Blob> {
    const url = URL.createObjectURL(file);
    try {
      const img = new Image();
      img.decoding = 'async';
      img.src = url;
      try {
        await img.decode();
      } catch {
        throw new Error(`Could not decode "${file.name}". The file may be corrupt or an unsupported format.`);
      }
      const width  = img.naturalWidth;
      const height = img.naturalHeight;
      if (!width || !height) throw new Error(`"${file.name}" has no readable image data.`);

      const canvas = document.createElement('canvas');
      canvas.width  = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d');
      if (!ctx) throw new Error('Canvas 2D context is unavailable in this browser.');
      ctx.drawImage(img, 0, 0);

      const blob = await new Promise<Blob | null>((resolve) => canvas.toBlob(resolve, 'image/png'));
      if (!blob) throw new Error('Failed to convert the image to PNG.');
      return blob;
    } finally {
      URL.revokeObjectURL(url);
    }
  }

  // ── Output filename ─────────────────────────────────────────────────────────
  // Take up to the first 6 characters of the original base name and append the
  // brand suffix, e.g. "image.jpg" -> "image_freeremovebg.com.png".
  // Sanitises odd characters and de-duplicates so a batch never collides.
  function buildOutName(originalName: string): string {
    const base = originalName.replace(/\.[^/.]+$/, '');
    let stub = base.replace(/[^a-zA-Z0-9]/g, '').slice(0, 6).toLowerCase();
    if (!stub) stub = 'image';
    let candidate = `${stub}_freeremovebg.com.png`;
    let n = 2;
    while (usedNames.has(candidate)) {
      candidate = `${stub}-${n}_freeremovebg.com.png`;
      n++;
    }
    usedNames.add(candidate);
    return candidate;
  }

  // ── Process one image ─────────────────────────────────────────────────────
  async function processImage(item: QueueItem): Promise<void> {
    const originalUrl = URL.createObjectURL(item.file);
    item.originalUrl = originalUrl;
    let workingUrl: string | null = null;
    try {
      // Normalise to PNG so every engine receives a format it can reliably decode.
      const pngBlob = await normalizeToPng(item.file);
      workingUrl = URL.createObjectURL(pngBlob);
      const { blob, usedModel } = await removeBg(pngBlob, workingUrl, item.id);
      const resultUrl = URL.createObjectURL(blob);
      const name = buildOutName(item.file.name);
      item.resultUrl = resultUrl;
      item.outName = name;
      item.blob = blob;
      item.cardEl = addCard(name, originalUrl, resultUrl, usedModel);
      setThumbStatus(item.id, 'done');
    } catch (err) {
      setThumbStatus(item.id, 'error');
      throw err;
    } finally {
      if (workingUrl) URL.revokeObjectURL(workingUrl);
    }
  }

  // ── Result card ───────────────────────────────────────────────────────────
  function addCard(name: string, originalUrl: string, processedUrl: string, modelLabel: string): HTMLElement {
    const card = document.createElement('div');
    card.className = 'bg-canvas border border-hairline rounded-[10px] overflow-hidden shadow-sm';
    card.innerHTML = `
      <div class="relative aspect-[4/3] grid grid-cols-2">
        <div class="relative overflow-hidden border-r border-hairline">
          <img src="${originalUrl}" alt="Original" class="w-full h-full object-cover block" />
          <span class="absolute top-2 left-2 px-2 py-[3px] bg-ink text-on-primary text-[11px] font-medium rounded-[4px]">Original</span>
        </div>
        <div class="relative overflow-hidden bg-checkerboard">
          <img src="${processedUrl}" alt="Background removed" class="w-full h-full object-cover block" />
          <span class="absolute top-2 right-2 px-2 py-[3px] bg-link text-white text-[11px] font-medium rounded-[4px]">Removed</span>
        </div>
      </div>
      <div class="px-4 pt-3 pb-3.5 border-t border-canvas-soft-2">
        <div class="flex items-center justify-between gap-3 mb-2">
          <p class="text-[13px] font-medium text-ink m-0 overflow-hidden text-ellipsis whitespace-nowrap flex-1">${name}</p>
          <button class="dl-btn shrink-0 px-4 py-[7px] bg-ink text-on-primary border-none rounded-pill text-[13px] font-medium cursor-pointer transition-opacity hover:opacity-80">
            Download PNG
          </button>
        </div>
        <p class="m-0 text-[11px] text-mute font-mono">
          <span class="inline-block w-[7px] h-[7px] rounded-full bg-link mr-[5px] align-middle"></span>
          ${modelLabel}
        </p>
      </div>
    `;
    imagesContainer.appendChild(card);
    imageGrid.classList.remove('hidden');
    (card.querySelector('.dl-btn') as HTMLButtonElement).addEventListener('click', () => {
      const a = document.createElement('a');
      a.href = processedUrl;
      a.download = name;
      a.click();
    });
    return card;
  }

  // ── Main handler ──────────────────────────────────────────────────────────
  // Accept anything the browser can decode as an image. We check the MIME type
  // first, then fall back to the file extension for files that arrive with an
  // empty or generic type (common with some WebP/AVIF downloads).
  const IMAGE_EXT = /\.(jpe?g|png|webp|gif|bmp|avif|svg|ico|tiff?)$/i;
  function isImageFile(f: File): boolean {
    return f.type.startsWith('image/') || IMAGE_EXT.test(f.name);
  }

  async function handleFiles(newFiles: File[]) {
    const imgs = newFiles.filter(isImageFile);
    if (!imgs.length) { alert('Please select image files (JPG, PNG, WebP, GIF, BMP, AVIF, and more).'); return; }

    // Wrap each new file in a queue item with a stable id, then render thumbs.
    const newItems: QueueItem[] = imgs.map(file => ({ id: nextId(), file, status: 'queued' as ThumbStatus }));
    queue.push(...newItems);
    showFilesInZone(newItems);

    progressState.classList.remove('hidden');
    const total = newItems.length;
    let done = 0;
    setProgress(done, total, 'Starting…');

    for (const item of newItems) {
      // The item may have been removed from the zone before we reached it.
      if (!queue.includes(item)) { done++; setProgress(done, total, 'Processing…'); continue; }
      setProgress(done, total, `Processing ${item.file.name}…`);
      try {
        await processImage(item);
      } catch (err) {
        console.error(`Skipping ${item.file.name}:`, err);
      }
      done++;
      setProgress(done, total, done === total ? 'All done!' : 'Processing…');
    }

    if (done === total) setTimeout(() => { progressState.classList.add('hidden'); }, 2000);
  }

  // ── ZIP download ──────────────────────────────────────────────────────────
  async function downloadZip() {
    const ready = queue.filter(q => q.blob && q.outName);
    if (!ready.length) return;
    const zip = new JSZip();
    ready.forEach(({ outName, blob }) => zip.file(outName!, blob!));
    const zipBlob = await zip.generateAsync({ type: 'blob' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(zipBlob);
    a.download = 'freeremovebg.com.zip';
    a.click();
  }

  // ── Event wiring ──────────────────────────────────────────────────────────
  const DRAG_ON  = ['border-ink', 'bg-canvas-soft'];
  const DRAG_OFF = ['border-hairline-strong', 'bg-canvas'];

  function setDragState(active: boolean) {
    uploadZone.classList.remove(...(active ? DRAG_OFF : DRAG_ON));
    uploadZone.classList.add(...(active ? DRAG_ON : DRAG_OFF));
  }

  uploadZone.addEventListener('click', () => {
    if (!uploadZone.classList.contains('has-files')) fileInput.click();
  });
  browseBtn.addEventListener('click',  (e) => { e.stopPropagation(); fileInput.click(); });
  addMoreBtn.addEventListener('click', (e) => { e.stopPropagation(); fileInput.click(); });
  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) handleFiles(Array.from(fileInput.files));
    fileInput.value = '';
  });
  uploadZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    if (!uploadZone.classList.contains('has-files')) setDragState(true);
  });
  uploadZone.addEventListener('dragleave', () => {
    if (!uploadZone.classList.contains('has-files')) setDragState(false);
  });
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    if (!uploadZone.classList.contains('has-files')) setDragState(false);
    if (e.dataTransfer?.files.length) handleFiles(Array.from(e.dataTransfer.files));
  });
  downloadAllBtn.addEventListener('click', downloadZip);

  // ── Scroll-reveal for the SEO article ───────────────────────────────────────
  // Each [data-reveal] block fades/slides into place as it scrolls into view.
  const revealEls = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion || !('IntersectionObserver' in window)) {
    // Show everything immediately when motion is reduced or unsupported.
    revealEls.forEach(el => el.classList.add('is-visible'));
  } else {
    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target); // reveal once, then stop watching
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });

    revealEls.forEach(el => revealObserver.observe(el));
  }

</script>
