# build output
dist/

# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables — NEVER commit real secrets
# Ignore every .env variant, but keep the documented template (.env.example).
.env
.env.*
!.env.example

# Cloudflare: wrangler.toml is committed on purpose — it holds only non-secret
# config (routes, asset dir). Production secrets are uploaded via
# `wrangler secret put` and stored encrypted by Cloudflare, NOT in this file.
# If you ever add a [vars] secret or a .dev.vars file, ignore those instead:
.dev.vars
.dev.vars.*

# macOS-specific files
.DS_Store

# Playwright
.playwright/
playwright-report/
test-results/

# jetbrains setting folder
.idea/
