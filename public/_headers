# Cloudflare Workers static-asset response headers.
# ----------------------------------------------------------------------------
# This file is parsed by the ASSETS binding (see wrangler.toml) and applied to
# files served from ./dist. Authoring it in public/ means Astro copies it to
# the build output root on every build. It is parsed by Workers, never served.
#
# Requests to /_astro/* are served asset-first and never invoke the geo-routing
# Worker (run_worker_first = ["/"]), so these rules apply cleanly to them.

# Fingerprinted, content-hashed build output. Astro emits JS, inlined-CSS
# chunks, and the onnxruntime-web .wasm binaries here, each with a content hash
# in its filename (e.g. ort-wasm-simd-threaded.jsep.D5Jk56-t.wasm). The hash
# changes whenever the bytes change, so the URL is a stable, unique identity
# for that exact content -- safe to cache for a year and skip revalidation.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static root assets (favicons, PWA icons, manifest). These change rarely and
# are referenced by fixed filenames, so a 1-week cache with revalidation gives
# repeat visitors a speed boost while still picking up changes reasonably fast.
/favicon.svg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/favicon.ico
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/favicon-96x96.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/web-app-manifest-192x192.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/web-app-manifest-512x512.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/site.webmanifest
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# NOTE: model files (.onnx) are intentionally NOT listed here. The client loads
# them from huggingface.co at runtime (env.allowRemoteModels = true), so their
# caching is governed by that origin's headers, not ours. All .wasm files this
# site serves live under /_astro/ and are already covered by the rule above.
#
# HTML pages and /sitemap.xml are deliberately left on the Workers default of
# "Cache-Control: public, max-age=0, must-revalidate", which keeps content
# fresh by revalidating (via ETag) on every request. Do NOT add a Cache-Control
# to the /* rule below: a duplicate Cache-Control would be comma-joined onto the
# immutable rule above, corrupting the long-cache behavior for /_astro/* assets.

# Security headers applied to every response.
#
# Content-Security-Policy is delivered HERE as an HTTP header (not via Astro's
# <meta> tag) on purpose: Cloudflare rewrites the HTML body at the edge (Web
# Analytics beacon, optionally Rocket Loader / email obfuscation), which injects
# inline scripts AFTER the build — so a hash/nonce CSP can never match them. A
# header CSP is applied by the edge regardless of body rewriting, and is also
# Lighthouse's preferred delivery method.
#
# script-src rationale (the app is a client-side WASM AI tool):
#   - 'self'            : Astro's bundled module scripts.
#   - blob:             : onnxruntime-web loads its backend from a runtime
#                         blob: script URL — REQUIRED or every cutout fails with
#                         "no available backend found".
#   - 'wasm-unsafe-eval': compile the ONNX/imgly WebAssembly modules.
#   - 'unsafe-inline'   : the theme/GTM/font inline bootstraps AND Cloudflare's
#                         edge-injected inline scripts (whose content rotates and
#                         cannot be hashed ahead of time). Modern browsers ignore
#                         'unsafe-inline' when a hash/nonce is present, so we use
#                         no hashes here — this keeps inline execution working.
#   - https hosts       : jsDelivr (ORT backend), GTM/GA, Cloudflare Insights.
# connect-src: model/WASM downloads (HF + jsDelivr), analytics beacons, blob/data.
# worker-src / child-src: blob: for the ONNX web workers.
# frame-ancestors 'none' + X-Frame-Options: clickjacking protection (header-only).
#
# No Cache-Control is set here, so the cache rules above are untouched.
#
# ── AdSense (future) ─────────────────────────────────────────────────────────
# When integrating AdSense, extend the directives below with Google's origins:
#   script-src : add https://pagead2.googlesyndication.com
#                    https://partner.googleadservices.com
#                    https://tpc.googlesyndication.com https://adservice.google.com
#   frame-src  : add https://googleads.g.doubleclick.net
#                    https://tpc.googlesyndication.com https://www.google.com
#   img-src    : add https://*.g.doubleclick.net https://*.googlesyndication.com
#   connect-src: add https://pagead2.googlesyndication.com https://*.g.doubleclick.net
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob: https://cdn.jsdelivr.net https://static.cloudflareinsights.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://www.googletagmanager.com https://www.google-analytics.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://huggingface.co https://*.hf.co https://cdn-lfs.huggingface.co https://*.huggingface.co https://cdn.jsdelivr.net https://www.googletagmanager.com https://www.google-analytics.com https://cloudflareinsights.com https://static.cloudflareinsights.com blob: data:; worker-src 'self' blob:; child-src 'self' blob:; form-action 'self' https://formsubmit.co; frame-ancestors 'none'
