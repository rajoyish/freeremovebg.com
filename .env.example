# Copy this file to `.env` and fill in the real value. `.env` is gitignored.
#
# Google Cloud Translation API key. Used ONLY at build time by
# `scripts/translate.js` (run via `pnpm run translate`). It must stay
# server-side: do NOT rename it with a PUBLIC_ prefix, or Astro will expose it
# to the client browser.
#
# In Cloudflare production this is supplied separately as an encrypted secret:
#   wrangler secret put GOOGLE_TRANSLATE_API_KEY
GOOGLE_TRANSLATE_API_KEY=
